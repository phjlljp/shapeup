{
  "description": "Ripple-check hook for shaping documents",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/shaping-ripple.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
